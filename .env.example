# Copy to `.env` and fill in. `.env` is gitignored.
# Loaded by `python-dotenv` in src/mathnet_eval/inference.py.

ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-...
GOOGLE_API_KEY=...

# Optional: HuggingFace token for gated datasets/models
HF_TOKEN=hf_...

# Optional: override the HF cache location (on Hyak, point to scratch to avoid home-dir quota)
# HF_HOME=/gscratch/scrubbed/sanmarco/hf_cache
